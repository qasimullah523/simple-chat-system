<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<h2> All chats </h2>
<form method ="get" action="/chats/new"> 
    <button> New Chat</button>
    <br />
</form>
<%for(let chat of chats){ %>
    <div class="chat">
         <p> From: <%= chat.from %> </p>
        <div class="msg"> 
            <p> Message: <%= chat.msg %> </p>
            <form method="get" action="/chats/<%= chat._id %>/edit"> 
                <button> edit </button>
            </form>

            <form method="post" action="/chats/<%= chat._id %>?_method=DELETE"> 
                <button> delete </button>   
            
        </div>
        
     <hr>
        <p> Received by : <%= chat.to %> </p>
       <p> Created at: <%= chat.created_at.toString().split(' ')[4] %> </p>
         <p> Created at: <%= chat.created_at.toString().split(' ').slice(0,4).join('_')%> </p>
    </div>
    <br/> <br>
    
<%} %>

    
</body>
</html>

