<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    
    <p>Edit your  Chat <%=chat.id %>  </p>  
    <br> </br>
    <p> this chat  was send from  <%=chat.from %> to <%= chat.to %> </p>

    <form method="post" action="/chats/<%= chat._id %>?_method=PUT">
        

        <textarea name="msg" rows="6"cols="50"> <%= chat.msg %> </textarea>
        <br> </br>
        <button> Edit Chat</button>
       
    </form>
</body>
</html>


